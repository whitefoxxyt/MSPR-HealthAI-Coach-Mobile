# Environment variables for HealthAi Coach Mobile App

# Auth Service
AUTH_SERVICE_URL=http://localhost:3000/api

# Main API Service
API_SERVICE_URL=http://localhost:8080/api

# AI Nutrition Service
AI_NUTRITION_URL=http://localhost:8001/api/v1

# Reco Fitness Service
RECO_FITNESS_URL=http://localhost:8002/api/v1

# For Android emulator, use 10.0.2.2 instead of localhost
# Example for Android:
# AUTH_SERVICE_URL=http://10.0.2.2:3000/api

# BetterAuth configuration
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8081